# Copy file ini jadi ".env" untuk development lokal.
# Di Render, isi variable yang sama lewat Dashboard > Environment (JANGAN commit .env ke Git)

PORT=3000

# JWT untuk token login admin
JWT_SECRET=ganti-dengan-string-acak-yang-panjang

# Kredensial admin (bukan disimpan di Sheets, demi keamanan & kecepatan)
ADMIN_USERNAME=admin
# Generate hash dengan: node -e "console.log(require('bcryptjs').hashSync('password_anda', 10))"
ADMIN_PASSWORD_HASH=

# Google Apps Script Web App (dari deployment Code_v2.gs)
SHEETS_WEB_APP_URL=https://script.google.com/macros/s/xxxxx/exec
SHEETS_API_KEY=ganti-dengan-kunci-rahasia-baru
